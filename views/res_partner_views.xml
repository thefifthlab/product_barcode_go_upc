<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_vendor_number" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.vendor.number</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <xpath expr="//div[hasclass('oe_title')]" position="before">
                    <div class="o_horizontal_separator" style="margin-bottom: 5px;">
                        <span style="font-weight: bold; font-size: 1.1rem;">Vendor/Customer Number:</span>
                        <field name="vendor_number" class="oe_inline" placeholder="V000001 or C00001"
                               style="font-size: 1.1rem; margin-left: 10px;"/>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="view_partner_tree_vendor_number" model="ir.ui.view">
            <field name="name">res.partner.tree.inherit.vendor.number</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='complete_name']" position="before">
                    <field name="vendor_number" optional="show" string="Vendor"/>
                </xpath>
            </field>
        </record>

        <record id="view_res_partner_filter_vendor_number" model="ir.ui.view">
            <field name="name">res.partner.select.inherit.vendor.number</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="vendor_number" string="Vendor Number"
                           filter_domain="[('vendor_number', 'ilike', self)]"/>
                </xpath>
            </field>
        </record>

        <record id="view_partner_kanban_card_vendor_number_before_name" model="ir.ui.view">
            <field name="name">res.partner.kanban.card.inherit.vendor.number.before.name</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.res_partner_kanban_view"/>
            <field name="arch" type="xml">

                <!-- Insert field declarations INSIDE the <kanban> root of the parent view -->
                <xpath expr="//kanban" position="inside">
                    <field name="vendor_number"/>
                    <!-- If using the supplier check: -->
                    <field name="supplier_rank"/>
                </xpath>

                <!-- Your badge (inside the card template) -->
                <xpath expr="//t[@t-name='card']" position="inside">
                    <t t-if="record.vendor_number.raw_value and record.supplier_rank.raw_value &gt; 0">
                        <span class="position-absolute top-0 start-0 badge rounded-pill bg-primary text-white fw-semibold px-2 py-1 m-2 shadow-sm"
                              style="font-size: 0.82rem; z-index: 15; min-width: 3.4rem; text-align: center;">
                            <t t-esc="record.vendor_number.value"/>
                        </span>
                    </t>
                </xpath>

            </field>
        </record>
    </data>
</odoo>