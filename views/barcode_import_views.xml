<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- SEPARATE LIST VIEW FOR LINES -->
    <record id="view_barcode_import_line_list" model="ir.ui.view">
        <field name="name">barcode.import.line.list</field>
        <field name="model">barcode.import.line</field>
        <field name="priority" eval="10"/>
        <field name="arch" type="xml">
            <list editable="bottom" create="true" delete="true">
                <field name="sequence" widget="handle"/>
                <field name="barcode" required="1"/>
                <field name="product_id" readonly="1" optional="hide"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'success'"
                       decoration-danger="status == 'error'"
                       decoration-warning="status == 'not_found'"
                       decoration-info="status == 'pending'"/>
                <field name="message" optional="show"/>
            </list>
        </field>
    </record>

    <!-- MAIN FORM VIEW -->
    <record id="view_barcode_import_form" model="ir.ui.view">
        <field name="name">barcode.import.form</field>
        <field name="model">barcode.import</field>
        <field name="arch" type="xml">
            <form string="Bulk Barcode Import">
                <sheet>
                    <!-- Action buttons – replaced attrs with direct invisible -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_process_bulk"
                                type="object"
                                string="Process All"
                                class="oe_stat_button"
                                icon="fa-play-circle"
                                invisible="state != 'draft'"/>
                        <button name="action_retry_failed"
                                type="object"
                                string="Retry Failed / Not Found"
                                class="oe_stat_button"
                                icon="fa-repeat"
                                invisible="state != 'processed'"/>
                    </div>

                    <!-- Header -->
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'draft'"
                                   decoration-success="state == 'processed'"/>
                        </group>
                        <group>
                            <field name="success_count" widget="progressbar"
                                   options="{'max_value': 100}"/>
                            <field name="not_found_count"/>
                            <field name="error_count"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Lines tab -->
                        <page string="Barcodes / Lines">
                            <field name="line_ids" nolabel="1"
                                   context="{'tree_view_ref': 'product_barcode_go_upc.view_barcode_import_line_list'}">
                                <list/>
                            </field>
                        </page>

                        <!-- Error Log -->
                        <page string="Error Log" invisible="not error_log">
                            <field name="error_log" nolabel="1" widget="text" readonly="1"/>
                        </page>

                        <!-- Chatter -->
                        <page string="Chatter" name="chatter">
                            <field name="message_ids" widget="mail_thread"/>
                            <field name="activity_ids" widget="mail_activity"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- MAIN LIST VIEW FOR IMPORTS -->
    <record id="view_barcode_import_list" model="ir.ui.view">
        <field name="name">barcode.import.list</field>
        <field name="model">barcode.import</field>
        <field name="arch" type="xml">
            <list string="Bulk Barcode Imports">
                <field name="name"/>
                <field name="state" widget="badge"/>
                <field name="success_count"/>
                <field name="not_found_count"/>
                <field name="error_count"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_barcode_import" model="ir.actions.act_window">
        <field name="name">Bulk Barcode Imports</field>
        <field name="res_model">barcode.import</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new bulk barcode import to process multiple barcodes at once using Barcode Lookup API.
            </p>
        </field>
    </record>

    <!-- MENUS -->
    <menuitem id="menu_barcode_import_root"
              name="Barcode Bulk Import"
              parent="stock.menu_stock_root"
              sequence="45"
              groups="stock.group_stock_manager"/>

    <menuitem id="menu_barcode_import"
              name="Bulk Barcode Imports"
              parent="menu_barcode_import_root"
              action="action_barcode_import"
              sequence="10"/>

</odoo>